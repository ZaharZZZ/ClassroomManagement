@model ClassroomManagement.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Вход в систему";
    Layout = null; // Без навигации для страницы входа
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Вход — Управление аудиторным фондом</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        body {
            background: linear-gradient(135deg, #1a3a5c 0%, #2d6a9f 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }
        .login-card {
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }
        .login-header {
            background: linear-gradient(135deg, #1a3a5c, #2d6a9f);
            border-radius: 16px 16px 0 0;
            padding: 2rem;
            text-align: center;
            color: white;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card login-card">
                    <div class="login-header">
                        <i class="bi bi-building" style="font-size: 3rem;"></i>
                        <h4 class="mt-2 mb-0">Управление аудиторным фондом</h4>
                        <small class="opacity-75">Образовательная организация</small>
                    </div>
                    <div class="card-body p-4">
                        <form asp-action="Login" method="post">
                            @Html.AntiForgeryToken()

                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-danger">
                                    <i class="bi bi-exclamation-triangle"></i>
                                    @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                                </div>
                            }

                            <div class="mb-3">
                                <label asp-for="Login" class="form-label fw-semibold">
                                    <i class="bi bi-person"></i> Логин
                                </label>
                                <input asp-for="Login" class="form-control form-control-lg"
                                       placeholder="Введите логин" autocomplete="username" />
                                <span asp-validation-for="Login" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Password" class="form-label fw-semibold">
                                    <i class="bi bi-lock"></i> Пароль
                                </label>
                                <input asp-for="Password" class="form-control form-control-lg"
                                       placeholder="Введите пароль" autocomplete="current-password" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100">
                                <i class="bi bi-box-arrow-in-right"></i> Войти
                            </button>
                        </form>
                    </div>
                    <div class="card-footer text-center text-muted small py-3">
                        Доступ только для авторизованных сотрудников
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>