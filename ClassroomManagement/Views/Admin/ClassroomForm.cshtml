@model ClassroomManagement.Models.ViewModels.ClassroomFormViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Добавить кабинет" : "Редактировать кабинет";
    var isEdit = Model.Id != 0;
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="bi bi-@(isEdit ? "pencil" : "plus-circle")"></i>
                    @ViewData["Title"]
                </h5>
            </div>
            <div class="card-body">
                <form asp-action="@(isEdit ? "EditClassroom" : "CreateClassroom")"
                      method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="Number" class="form-label fw-semibold"></label>
                            <input asp-for="Number" class="form-control"
                                   placeholder="Например: 101" />
                            <span asp-validation-for="Number" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="BuildingId" class="form-label fw-semibold"></label>
                            <select asp-for="BuildingId" asp-items="Model.Buildings"
                                    class="form-select">
                                <option value="">— Выберите корпус —</option>
                            </select>
                            <span asp-validation-for="BuildingId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Floor" class="form-label fw-semibold"></label>
                            <input asp-for="Floor" type="number" class="form-control"
                                   min="1" max="20" />
                            <span asp-validation-for="Floor" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="RoomTypeId" class="form-label fw-semibold"></label>
                            <select asp-for="RoomTypeId" asp-items="Model.RoomTypes"
                                    class="form-select">
                                <option value="">— Выберите тип —</option>
                            </select>
                            <span asp-validation-for="RoomTypeId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Capacity" class="form-label fw-semibold"></label>
                            <input asp-for="Capacity" type="number" class="form-control"
                                   min="1" max="1000" />
                            <span asp-validation-for="Capacity" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ConditionId" class="form-label fw-semibold"></label>
                            <select asp-for="ConditionId" asp-items="Model.Conditions"
                                    class="form-select">
                                <option value="">— Выберите состояние —</option>
                            </select>
                            <span asp-validation-for="ConditionId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DepartmentId" class="form-label fw-semibold"></label>
                            <select asp-for="DepartmentId" asp-items="Model.Departments"
                                    class="form-select">
                                <option value="">— Без отделения —</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="SelectedTeacherId" class="form-label fw-semibold"></label>
                            <select asp-for="SelectedTeacherId" asp-items="Model.TeachersList" class="form-select">
                                <option value="">— Не закреплён —</option>
                            </select>
                        </div>

                        <!-- Скрытое поле для совместимости (можно удалить) -->
                        <input type="hidden" asp-for="LongTermBookingBy" />

                        <div class="col-md-6">
                            <label asp-for="LongTermUntil" class="form-label fw-semibold"></label>
                            <input asp-for="LongTermUntil" type="datetime-local"
                                   class="form-control" />
                        </div>

                        <div class="col-12">
                            <label asp-for="EquipmentNote" class="form-label fw-semibold"></label>
                            <textarea asp-for="EquipmentNote" class="form-control" rows="2"
                                      placeholder="Описание оборудования..."></textarea>
                        </div>

                        <!-- Оборудование (чекбоксы) -->
                        @if (Model.EquipmentList.Any())
                        {
                            <div class="col-12">
                                <label class="form-label fw-semibold">Оборудование</label>
                                <div class="row row-cols-2 row-cols-md-3 g-2">
                                    @for (int i = 0; i < Model.EquipmentList.Count; i++)
                                    {
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox"
                                                       name="SelectedEquipmentIds"
                                                       value="@Model.EquipmentList[i].Id"
                                                       id="eq_@Model.EquipmentList[i].Id"
                                                @(Model.EquipmentList[i].IsSelected ? "checked" : "") />
                                                <label class="form-check-label"
                                                       for="eq_@Model.EquipmentList[i].Id">
                                                    @Model.EquipmentList[i].Name
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i>
                            @(isEdit ? "Сохранить изменения" : "Добавить кабинет")
                        </button>
                        <a asp-action="Classrooms" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Отмена
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}