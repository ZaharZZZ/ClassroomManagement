@{
    ViewData["Title"] = "Панель администратора";
}

<h4 class="mb-4"><i class="bi bi-gear"></i> Панель администратора</h4>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card border-primary h-100">
            <div class="card-body text-center">
                <i class="bi bi-door-open text-primary" style="font-size:3rem;"></i>
                <h5 class="mt-2">Кабинеты</h5>
                <p class="text-muted small">Добавление, редактирование и удаление кабинетов</p>
                <a asp-action="Classrooms" class="btn btn-primary btn-sm">Управление</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-success h-100">
            <div class="card-body text-center">
                <i class="bi bi-people text-success" style="font-size:3rem;"></i>
                <h5 class="mt-2">Пользователи</h5>
                <p class="text-muted small">Управление учётными записями и ролями</p>
                <a asp-action="Users" class="btn btn-success btn-sm">Управление</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-warning h-100">
            <div class="card-body text-center">
                <i class="bi bi-diagram-3 text-warning" style="font-size:3rem;"></i>
                <h5 class="mt-2">Отделения</h5>
                <p class="text-muted small">Управление отделениями и преподавателями</p>
                <a asp-action="Departments" class="btn btn-warning btn-sm">Управление</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-secondary h-100">
            <div class="card-body text-center">
                <i class="bi bi-list-ul text-secondary" style="font-size:3rem;"></i>
                <h5 class="mt-2">Журнал аудита</h5>
                <p class="text-muted small">Просмотр действий пользователей</p>
                <a asp-action="AuditLog" class="btn btn-secondary btn-sm">Просмотр</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-info h-100">
            <div class="card-body text-center">
                <i class="bi bi-calendar3 text-info" style="font-size:3rem;"></i>
                <h5 class="mt-2">Расписание</h5>
                <p class="text-muted small">Просмотр расписания аудиторного фонда</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-info btn-sm">Перейти</a>
            </div>
        </div>
    </div>
</div>