@model List<ClassroomManagement.Models.Entities.Classroom>
@{
    ViewData["Title"] = "Управление кабинетами";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-door-open"></i> Управление кабинетами</h4>
    <a asp-action="CreateClassroom" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Добавить кабинет
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>Номер</th>
                <th>Корпус</th>
                <th>Этаж</th>
                <th>Тип</th>
                <th>Вместимость</th>
                <th>Состояние</th>
                <th>Отделение</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td><strong>@c.Number</strong></td>
                    <td>@c.Building.Name</td>
                    <td>@c.Floor</td>
                    <td>@c.RoomType.Name</td>
                    <td>@c.Capacity</td>
                    <td>
                        <span class="badge @(c.Condition.Name == "Исправна" ? "bg-success" : "bg-danger")">
                            @c.Condition.Name
                        </span>
                    </td>
                    <td>@(c.Department?.Abbreviation ?? "—")</td>
                    <td>
                        <a asp-action="EditClassroom" asp-route-id="@c.Id"
                           class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="DeleteClassroom" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@c.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Удалить кабинет @c.Number?')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>