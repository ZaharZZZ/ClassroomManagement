@model List<ClassroomManagement.Models.Entities.User>
@{
    ViewData["Title"] = "Управление пользователями";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-people"></i> Управление пользователями</h4>
    <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createUserModal">
        <i class="bi bi-person-plus"></i> Добавить пользователя
    </button>
</div>

<div class="table-responsive">
    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Логин</th>
                <th>Роль</th>
                <th>Преподаватель</th>
                <th>Дата создания</th>
                <th>Последний вход</th>
                <th>Статус</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr class="@(user.IsBlocked ? "table-secondary text-muted" : "")">
                    <td>@user.Id</td>
                    <td>
                        <strong>@user.Login</strong>
                    </td>
                    <td>
                        @{
                            string roleBadge = user.Role.Name switch
                            {
                                "Admin" => "bg-danger",
                                "Dispatcher" => "bg-warning text-dark",
                                "Teacher" => "bg-info text-dark",
                                _ => "bg-secondary"
                            };
                            string roleText = user.Role.Name switch
                            {
                                "Admin" => "Администратор",
                                "Dispatcher" => "Диспетчер",
                                "Teacher" => "Преподаватель",
                                _ => user.Role.Name
                            };
                        }
                        <span class="badge @roleBadge">@roleText</span>
                    </td>
                    <td>@(user.Teacher?.FullName ?? "—")</td>
                    <td>
                        <small>@user.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                    </td>
                    <td>
                        <small>
                            @(user.LastLogin.HasValue
                                ? user.LastLogin.Value.ToString("dd.MM.yyyy HH:mm")
                                : "Не входил")
                        </small>
                    </td>
                    <td>
                        @if (user.IsBlocked)
                        {
                            <span class="badge bg-danger">
                                <i class="bi bi-lock"></i> Заблокирован
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">
                                <i class="bi bi-unlock"></i> Активен
                            </span>
                        }
                    </td>
                    <td>
                        <form asp-action="ToggleUserBlock" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit"
                                    class="btn btn-sm @(user.IsBlocked ? "btn-outline-success" : "btn-outline-warning")"
                                    title="@(user.IsBlocked ? "Разблокировать" : "Заблокировать")"
                                    onclick="return confirm('@(user.IsBlocked ? "Разблокировать" : "Заблокировать") пользователя @user.Login?')">
                                <i class="bi bi-@(user.IsBlocked ? "unlock" : "lock")"></i>
                            </button>
                        </form>

                        <button class="btn btn-sm btn-outline-primary"
                                onclick="openChangePassword(@user.Id, '@user.Login')"
                                title="Сменить пароль">
                            <i class="bi bi-key"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Модальное окно создания пользователя -->
<div class="modal fade" id="createUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">
                    <i class="bi bi-person-plus"></i> Новый пользователь
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateUser" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Логин <span class="text-danger">*</span>
                        </label>
                        <input type="text" name="login" class="form-control"
                               required maxlength="100"
                               placeholder="Введите логин" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Пароль <span class="text-danger">*</span>
                        </label>
                        <input type="password" name="password" class="form-control"
                               required minlength="6"
                               placeholder="Минимум 6 символов" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Роль <span class="text-danger">*</span>
                        </label>
                        <select name="roleId" class="form-select" required
                                onchange="toggleTeacherSelect(this.value)">
                            <option value="">— Выберите роль —</option>
                            @foreach (var role in ViewBag.Roles as IEnumerable<ClassroomManagement.Models.Entities.Role> ?? new List<ClassroomManagement.Models.Entities.Role>())
                            {
                                string roleDisplayName = role.Name switch
                                {
                                    "Admin" => "Администратор",
                                    "Dispatcher" => "Диспетчер учебной части",
                                    "Teacher" => "Преподаватель",
                                    _ => role.Name
                                };
                                <option value="@role.Id"
                                        data-role="@role.Name">
                                    @roleDisplayName
                                </option>
                            }
                        </select>
                    </div>
                    <div class="mb-3 d-none" id="teacherSelectBlock">
                        <label class="form-label fw-semibold">Преподаватель</label>
                        <select name="teacherId" class="form-select">
                            <option value="">— Выберите преподавателя —</option>
                            @foreach (var teacher in ViewBag.Teachers as IEnumerable<ClassroomManagement.Models.Entities.Teacher> ?? new List<ClassroomManagement.Models.Entities.Teacher>())
                            {
                                <option value="@teacher.Id">@teacher.FullName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Отмена
                    </button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-save"></i> Создать
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Модальное окно смены пароля -->
<div class="modal fade" id="changePasswordModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="bi bi-key"></i> Смена пароля
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="userId" id="changePasswordUserId" />
                    <p class="text-muted small">
                        Пользователь: <strong id="changePasswordUserLogin"></strong>
                    </p>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Новый пароль <span class="text-danger">*</span>
                        </label>
                        <input type="password" name="newPassword" class="form-control"
                               required minlength="6"
                               placeholder="Минимум 6 символов" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Отмена
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Сохранить
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleTeacherSelect(roleId) {
            var select = document.querySelector('select[name="roleId"]');
            var selectedOption = select.options[select.selectedIndex];
            var roleName = selectedOption ? selectedOption.dataset.role : '';
            var block = document.getElementById('teacherSelectBlock');
            if (roleName === 'Teacher') {
                block.classList.remove('d-none');
            } else {
                block.classList.add('d-none');
            }
        }

        function openChangePassword(userId, login) {
            document.getElementById('changePasswordUserId').value = userId;
            document.getElementById('changePasswordUserLogin').textContent = login;
            new bootstrap.Modal(document.getElementById('changePasswordModal')).show();
        }
    </script>
}