@model ClassroomManagement.Models.ViewModels.CreateBookingViewModel
@{
    // Парсим дату для отображения
    string displayDate = Model.EventDateStr;
    if (DateOnly.TryParse(Model.EventDateStr, out var parsedDate))
    {
        displayDate = parsedDate.ToString("dd.MM.yyyy");
    }
}

<!-- Информация о кабинете -->
<div class="card mb-3 border-success">
    <div class="card-header bg-success text-white py-2">
        <i class="bi bi-door-open"></i>
        Кабинет <strong>@Model.ClassroomNumber</strong>
    </div>
    <div class="card-body py-2">
        <div class="row g-2">
            <div class="col-6">
                <small class="text-muted d-block">Дата:</small>
                <strong>@displayDate</strong>
            </div>
            <div class="col-6">
                <small class="text-muted d-block">Пара:</small>
                <strong>@Model.PairTime</strong>
            </div>
            @if (Model.ClassroomCapacity > 0)
            {
                <div class="col-6">
                    <small class="text-muted d-block">Вместимость:</small>
                    <strong>@Model.ClassroomCapacity мест</strong>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.RoomTypeName))
            {
                <div class="col-6">
                    <small class="text-muted d-block">Тип:</small>
                    <strong>@Model.RoomTypeName</strong>
                </div>
            }
        </div>

        @if (Model.ClassroomEquipments != null && Model.ClassroomEquipments.Any())
        {
            <hr class="my-2" />
            <small class="text-muted d-block mb-1">
                <i class="bi bi-tools"></i> Оснащение:
            </small>
            <div class="d-flex flex-wrap gap-1">
                @foreach (var eq in Model.ClassroomEquipments)
                {
                    <span class="badge bg-info text-dark">
                        <i class="bi bi-check2"></i> @eq
                    </span>
                }
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.EquipmentNote))
        {
            <div class="mt-2">
                <small class="text-muted fst-italic">
                    <i class="bi bi-info-circle"></i> @Model.EquipmentNote
                </small>
            </div>
        }
    </div>
</div>

@if (Model.IsUrgent)
{
    <div class="alert alert-warning py-2 mb-3">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <strong>Срочная заявка</strong> — заявка на сегодня,
        будет помечена как приоритетная.
    </div>
}

<div id="teacherBookingMessage"></div>

<!-- Цель -->
<div class="mb-3">
    <label class="form-label fw-semibold">
        <i class="bi bi-chat-text"></i>
        Цель резервирования <span class="text-danger">*</span>
    </label>
    <textarea id="tbPurpose" class="form-control" rows="3"
              placeholder="Практическое занятие, лекция, консультация..."
              maxlength="500"></textarea>
    <div class="form-text">До 500 символов</div>
</div>

<!-- Периодичность -->
<div class="mb-3">
    <label class="form-label fw-semibold">
        <i class="bi bi-arrow-repeat"></i> Периодичность
    </label>
    <select id="tbPeriodicity" class="form-select"
            onchange="tbTogglePeriod(this.value)">
        <option value="once">Разово</option>
        <option value="weekly">Еженедельно</option>
        <option value="daily">Ежедневно (на неделю)</option>
    </select>
</div>

<div class="mb-3 d-none" id="tbPeriodEndBlock">
    <label class="form-label fw-semibold">Дата окончания периода</label>
    <input type="date" id="tbPeriodEnd" class="form-control"
           min="@Model.EventDateStr" />
</div>

<!-- Скрытые данные -->
<span id="tbData"
      data-classroom-id="@Model.ClassroomId"
      data-event-date="@Model.EventDateStr"
      data-start-time="@Model.StartTimeStr"
      data-end-time="@Model.EndTimeStr"
      data-pair-number="@Model.PairNumber"
      data-classroom-number="@Model.ClassroomNumber">
</span>

<div class="d-flex gap-2 justify-content-end mt-3">
    <button type="button" class="btn btn-secondary"
            data-bs-dismiss="modal">
        <i class="bi bi-x"></i> Отмена
    </button>
    <button type="button" class="btn btn-primary fw-semibold"
            id="tbSubmitBtn" onclick="tbSubmit()">
        <i class="bi bi-send"></i> Подать заявку
    </button>
</div>

<script>
    function tbTogglePeriod(v) {
        var b = document.getElementById('tbPeriodEndBlock');
        if (v !== 'once') b.classList.remove('d-none');
        else b.classList.add('d-none');
    }

    function tbSubmit() {
        var msg  = document.getElementById('teacherBookingMessage');
        var btn  = document.getElementById('tbSubmitBtn');
        var d    = document.getElementById('tbData');

        var classroomId  = d.dataset.classroomId;
        var eventDate    = d.dataset.eventDate;
        var startTime    = d.dataset.startTime;
        var endTime      = d.dataset.endTime;
        var pairNumber   = d.dataset.pairNumber;
        var purpose      = document.getElementById('tbPurpose').value.trim();
        var periodicity  = document.getElementById('tbPeriodicity').value;
        var periodEnd    = document.getElementById('tbPeriodEnd').value;

        // Валидация
        if (!purpose) {
            msg.innerHTML =
                '<div class="alert alert-warning py-2">' +
                '<i class="bi bi-exclamation-triangle"></i> ' +
                'Укажите цель резервирования</div>';
            return;
        }
        if (periodicity !== 'once' && !periodEnd) {
            msg.innerHTML =
                '<div class="alert alert-warning py-2">' +
                '<i class="bi bi-exclamation-triangle"></i> ' +
                'Укажите дату окончания периода</div>';
            return;
        }

        msg.innerHTML =
            '<div class="text-center py-2">' +
            '<div class="spinner-border spinner-border-sm text-primary"></div>' +
            ' Отправка заявки...</div>';
        btn.disabled = true;

        // Получаем CSRF токен
        var tokenEl = document.querySelector(
            'input[name="__RequestVerificationToken"]');
        var token = tokenEl ? tokenEl.value : '';

        var params = new URLSearchParams();
        params.append('classroomId',  classroomId);
        params.append('eventDateStr', eventDate);
        params.append('startTimeStr', startTime);
        params.append('endTimeStr',   endTime);
        params.append('pairNumber',   pairNumber);
        params.append('purpose',      purpose);
        params.append('periodicity',  periodicity);
        if (periodEnd) params.append('periodEndDateStr', periodEnd);
        if (token)     params.append('__RequestVerificationToken', token);

        console.log('Отправка заявки преподавателя:', params.toString());

        fetch('/Home/SubmitBooking', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: params.toString()
        })
        .then(function(r) {
            console.log('Ответ SubmitBooking:', r.status);
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.json();
        })
        .then(function(result) {
            console.log('Результат:', result);
            if (result.success) {
                msg.innerHTML =
                    '<div class="alert alert-success py-2">' +
                    '<i class="bi bi-check-circle-fill"></i> ' +
                    result.message + '</div>';
                setTimeout(function() {
                    var m = bootstrap.Modal.getInstance(
                        document.getElementById('bookingModal'));
                    if (m) m.hide();
                    location.reload();
                }, 2000);
            } else {
                msg.innerHTML =
                    '<div class="alert alert-danger py-2">' +
                    '<i class="bi bi-x-circle-fill"></i> ' +
                    result.message + '</div>';
                btn.disabled = false;
            }
        })
        .catch(function(err) {
            console.error('Ошибка:', err);
            msg.innerHTML =
                '<div class="alert alert-danger py-2">' +
                'Ошибка: ' + err.message + '</div>';
            btn.disabled = false;
        });
    }
</script>